# Leave empty to use the Vite dev proxy (recommended for local development).
# VITE_API_BASE_URL=

# Remote payments API (list/single-send) — defaults to port 8080.
# VITE_PROXY_TARGET=http://localhost:8080

# Coffee-shop async backend (payment-batches) — defaults to port 8081.
# VITE_BACKEND_TARGET=http://localhost:8081
